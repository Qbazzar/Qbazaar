              "raw": "{\n  \"phone\": \"{{test_phone}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/resend-otp",
              "host": ["{{base_url}}{{api_prefix}}"],
              "path": ["auth", "resend-otp"]
            }
          }
        },
        {
          "name": "POST /auth/forgot-password",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/forgot-password",
              "host": ["{{base_url}}{{api_prefix}}"],
              "path": ["auth", "forgot-password"]
            }
          }
        },
        {
          "name": "POST /auth/reset-password",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"token\": \"{{reset_token}}\",\n  \"password\": \"{{test_password}}\",\n  \"password_confirmation\": \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/reset-password",
              "host": ["{{base_url}}{{api_prefix}}"],
              "path": ["auth", "reset-password"]
            }
          }
        },
        {
          "name": "POST /auth/send-email-verification",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/send-email-verification",
              "host": ["{{base_url}}{{api_prefix}}"],
              "path": ["auth", "send-email-verification"]
            }
          }
        },
        {
          "name": "GET /auth/verify-email/:id/:hash",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/verify-email/{{verify_email_id}}/{{verify_email_hash}}?signature={{verify_email_signature}}",
              "host": ["{{base_url}}{{api_prefix}}"],
              "path": ["auth", "verify-email", "{{verify_email_id}}", "{{verify_email_hash}}"],
              "query": [
                { "key": "signature", "value": "{{verify_email_signature}}" }
              ]
            }
          }
        }
      ]
    }
  ]
}
