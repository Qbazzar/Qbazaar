# QBazaar API — production .env template (api.qbazaar.fleeteye.de · user fleeteye).
#
# Copy to /home/fleeteye/qbazaar/qbazaar-api/.env on the server, then:
#   php artisan key:generate
# and fill every __FILL_ME__.

APP_NAME=QBazaar
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.qbazaar.fleeteye.de

# Deep links in mailed/push notifications point at the FRONTEND, not the API.
WEB_URL=https://qbazaar.fleeteye.de

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_QA

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=__FILL_ME__
DB_USERNAME=__FILL_ME__
DB_PASSWORD=__FILL_ME__

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
# REQUIRED on a shared/WHM box — the `requirepass` from /etc/redis/redis.conf.
REDIS_PASSWORD=__FILL_ME__
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_HOST=__FILL_ME__
MAIL_PORT=587
MAIL_USERNAME=__FILL_ME__
MAIL_PASSWORD=__FILL_ME__
MAIL_FROM_ADDRESS="no-reply@qbazaar.fleeteye.de"
MAIL_FROM_NAME="${APP_NAME}"

# Search: database driver until Meilisearch is installed (deploy/README.md).
# After install: SCOUT_DRIVER=meilisearch + MEILISEARCH_KEY=<master key>.
SCOUT_DRIVER=database
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# Reverb: the app PUBLISHES to the local server (127.0.0.1:8080); the BROWSER
# connects to wss://api.qbazaar.fleeteye.de/app via the Apache proxy (those
# public values live in qbazaar-web/.env.production, not here).
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=qbazaar
REVERB_APP_KEY=__FILL_ME__
REVERB_APP_SECRET=__FILL_ME__
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# Leave UNSET in production. Setting this is a security risk.
OTP_FIXED_CODE=

TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=+974

# FCM web push — empty disables push cleanly. Path resolves against base_path().
FIREBASE_CREDENTIALS=

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

TELESCOPE_ENABLED=false
