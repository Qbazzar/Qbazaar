# QBazaar API — production .env template for www.miete.site (qb-user tenant).
#
# Copy this file to ~/qbazaar/qbazaar-api/.env on the VPS, then:
#   php artisan key:generate
# and fill in every placeholder marked with __FILL_ME__.

APP_NAME=QBazaar
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.miete.site

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_QA

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=__FILL_ME__
DB_USERNAME=__FILL_ME__
DB_PASSWORD=__FILL_ME__

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=__FILL_ME__
MAIL_PASSWORD=__FILL_ME__
MAIL_FROM_ADDRESS="no-reply@qbazaar.qa"
MAIL_FROM_NAME="${APP_NAME}"

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=__FILL_ME__

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=qbazaar
REVERB_APP_KEY=__FILL_ME__
REVERB_APP_SECRET=__FILL_ME__
REVERB_HOST=www.miete.site
REVERB_PORT=443
REVERB_SCHEME=https

# Leave UNSET in production. Setting this is a security risk.
OTP_FIXED_CODE=

TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=+974

FCM_PROJECT_ID=
FCM_CREDENTIALS=storage/app/firebase-credentials.json

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

TELESCOPE_ENABLED=false
